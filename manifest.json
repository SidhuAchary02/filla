{
  "manifest_version": 3,
  "name": "filla",
  "version": "1.0",
  "description": "Detect form fields and extract questions",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}